{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 build-data.py)",
      "Bash(python3 build-search-index.py)",
      "Bash(python3 generate-profiles.py)",
      "Bash(python3 build-category-pages.py)",
      "Bash(python3 build-sitemap-xml.py)",
      "Bash(python3 build-stats.py)",
      "Bash(python3 build-places.py)",
      "Bash(python3 build-minify.py)",
      "Bash(python3 build-webp.py)",
      "Bash(python3 build-og-images.py)",
      "Bash(python3 build-zips.py)",
      "Bash(python3 -m http.server:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(pip install -r requirements.txt)",
      "Read(//home/user/usmcmin-com/**)"
    ],
    "deny": [
      "Read(./data/scorecard.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/session-start.sh"
          }
        ]
      }
    ]
  }
}
