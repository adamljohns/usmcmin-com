    "updated": "2026-04-21",
    "description": "Domain-to-bias lookup. Seeded from the 80 most-cited domains in scorecard.json (which cover 96.3% of all source citations), plus a forward-looking list of mainstream media outlets we expect to cite during claim extraction. Bias ratings (where present) are drawn from the two best-known public bias-rating projects: AllSides and Ad Fontes Media. For state legislative sites, official .gov domains, and advocacy organizations not rated by either service, a `type` classification is provided so the UI can still render a truthful badge (e.g., 'Official Gov', 'Right think tank').",
    "attribution": {
      "allsides": {
        "name": "AllSides Media Bias Ratings",
        "url": "https://www.allsides.com/media-bias/ratings",
        "methodology_url": "https://www.allsides.com/media-bias/media-bias-rating-methods",
        "scale": ["Left", "Lean Left", "Center", "Lean Right", "Right"],
        "note": "AllSides ratings are based on blind bias surveys, editorial reviews, independent reviews, third-party data, and community feedback. Ratings can shift over time."
      },
      "ad_fontes_media": {
        "name": "Ad Fontes Media — Interactive Media Bias Chart",
        "url": "https://adfontesmedia.com/interactive-media-bias-chart/",
        "methodology_url": "https://adfontesmedia.com/how-ad-fontes-ranks-news-sources/",
        "scale": "Bias: -42 (most Left) to +42 (most Right). Reliability: 0 (unreliable/propaganda) to 64 (original fact reporting).",
        "note": "Ad Fontes rates individual articles and aggregates to source-level scores. Values here reflect the source-level aggregate at the time this file was last updated."
      }
    },
    "types": {
      "mainstream": "General-audience news outlet (print, TV, or digital).",
      "local_news": "Local or regional news outlet with primarily local coverage.",
      "think_tank": "Policy research organization; typically produces white papers and scorecards.",
      "advocacy": "Organization that openly advocates a political/policy position; includes PACs, scorecards, and issue groups.",
      "reference": "Non-partisan reference or civic-data project.",
      "official_gov": "Official government domain (federal, state, municipal, court, or legislative).",
      "legal": "Court opinion, bill text, or other primary legal document source.",
      "social": "Social media platform. Bias is user-driven; flag as social so visitors know to weigh accordingly.",
      "cdn": "Content-delivery or file-hosting service. Bias is inherited from whoever posted the file; display inherits from the document context if available.",
      "encyclopedia": "Community-edited or curated encyclopedia."
    },
    "curation_notes": "Where a domain's bias was not clearly findable from a primary AllSides or Ad Fontes page, the `allsides`/`ad_fontes_*` fields are omitted rather than guessed. A `lean` field is used on advocacy/think-tank entries to communicate the organization's self-declared or plainly-evident political orientation; this is not a claim of the same rigor as an AllSides rating and is presented differently in the UI."
  },
